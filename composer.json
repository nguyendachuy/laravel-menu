{
  "name": "nguyendachuy/laravel-menu",
  "description": "Laravel Menu Manager with drag and drop, roles and multilevel support",
  "license": "MIT",
  "authors": [
    {
      "name": "Nguyen Dac Huy",
      "email": "huy.cit@gmail.com"
    }
  ],
  "require": {
    "php": "^7.3|^8.2",
    "illuminate/support": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "NguyenHuy\\Menu\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "NguyenHuy\\Menu\\Providers\\MenuServiceProvider"
      ],
      "aliases": {
        "Menu": "NguyenHuy\\Menu\\Facades\\Menu"
      }
    }
  }
}
